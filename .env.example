# Django
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=False
ALLOWED_HOSTS=.ondigitalocean.app

# Database (DigitalOcean Managed PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@host:25060/db?sslmode=require

# CORS (your app's URL — needed only if frontend is on a different domain)
CORS_ALLOWED_ORIGINS=https://your-app.ondigitalocean.app

# CSRF trusted origins (same as your app URL)
CSRF_TRUSTED_ORIGINS=https://your-app.ondigitalocean.app

# Set to False on DigitalOcean App Platform (the platform handles SSL termination)
SECURE_SSL_REDIRECT=False
